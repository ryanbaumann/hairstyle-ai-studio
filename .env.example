# Local demo only: Vite exposes VITE_* values to the browser bundle.
# Do not use this for a production-owned secret.
VITE_GEMINI_API_KEY=replace_me_for_local_demo_only

# Production server-side secret: read this only from serverless/API code.
# Never expose this value to client-side Vite code.
GEMINI_API_KEY=replace_me_for_server_side_deployments
